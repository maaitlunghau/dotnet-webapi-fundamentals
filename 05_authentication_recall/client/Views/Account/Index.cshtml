@model List<Account>

<div class="container mt-3">
    <h2>Account List</h2>
    <table class="table">
        <thead>
            <tr>
                <th>Id</th>
                <th>Full Name</th>
                <th>Email</th>
                <th>Role</th>
                <th>Status</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr>
                    <td>@item.Id</td>
                    <td>@item.FullName</td>
                    <td>@item.Email</td>
                    <td>@item.Role</td>
                    <td>@item.Status</td>
                </tr>
            }
        </tbody>
    </table>
</div>