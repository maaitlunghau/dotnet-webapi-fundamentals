{
  "ReverseProxy": {
    "Routes": {
      "authRoute": {
        "ClusterId": "userCluster",
        "Match": {
          "Path": "/api/user/{**catch-all}"
        }
      },
      "orderRoute": {
        "ClusterId": "orderCluster",
        "Match": {
          "Path": "/api/order/{**catch-all}"
        }
      },
      "loyalRoute": {
        "ClusterId": "loyalCluster",
        "Match": {
          "Path": "/api/loyalty/{**catch-all}"
        }
      },
      "notifyRoute": {
        "ClusterId": "notifyCluster",
        "Match": {
          "Path": "/api/notification/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "userCluster": {
        "Destinations": {
          "authService1": {
            "Address": "http://localhost:5150/"
          }
        }
      },
      "orderCluster": {
        "Destinations": {
          "orderService1": {
            "Address": "http://localhost:5249/"
          }
        }
      },
      "loyalCluster": {
        "Destinations": {
          "loyalService1": {
            "Address": "http://localhost:5035/"
          }
        }
      },
      "notifyCluster": {
        "Destinations": {
          "notifyService1": {
            "Address": "http://localhost:4000/"
          }
        }
      }
    }
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}