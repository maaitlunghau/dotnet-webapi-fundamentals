@model client.Models.Product

@{
    ViewData["Title"] = "Thêm mới sản phẩm";
}

<div class="row justify-content-center mt-5">
    <div class="col-md-6 border rounded p-4 shadow-lg bg-light">
        <h2 class="text-center text-success mb-4">THÊM MỚI SẢN PHẨM</h2>
        
        <form asp-action="Create" method="post" enctype="multipart/form-data">
            <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

            <div class="mb-3">
                <label asp-for="Name" class="form-label font-weight-bold">Tên (Name)</label>
                <input asp-for="Name" class="form-control" placeholder="Từ 3 đến 10 ký tự" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Price" class="form-label font-weight-bold">Giá (Price)</label>
                <input asp-for="Price" type="number" class="form-control" placeholder="Từ 100 đến 400" />
                <span asp-validation-for="Price" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Status" class="form-label font-weight-bold">Trạng thái (Status)</label>
                <div class="form-check">
                    <input asp-for="Status" class="form-check-input" type="checkbox" checked />
                    <label class="form-check-label">Active (Bỏ check là Disactive)</label>
                </div>
            </div>

            <div class="mb-3">
                <label class="form-label font-weight-bold">Hình ảnh (Image)</label>
                <input type="file" name="formFile" class="form-control" accept="image/*" required />
                <span asp-validation-for="Image" class="text-danger"></span>
            </div>

            <div class="d-grid mt-4">
                <button type="submit" class="btn btn-success btn-lg">Gửi dữ liệu lên Web API</button>
            </div>
            <div class="text-center mt-3">
                <a asp-action="Index" class="btn btn-secondary">Quay lại danh sách</a>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
